---
import '@/styles/global.css';
import Header from '@/components/layout/Header.astro';
import ThemeToggle from '@/components/islands/ThemeToggle.astro';
import { siteConfig } from '@/config/navigation';

interface Props {
  title: string;
  description?: string;
  currentPath: string;
  canonical?: string;
}

const { title, description = siteConfig.description, currentPath, canonical } = Astro.props;

const fullTitle = title === siteConfig.title ? title : `${title} | FRC Aides`;
const baseUrl = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const canonicalUrl =
  canonical ??
  `${siteConfig.url}${currentPath === '/' || currentPath === '' ? '/' : currentPath}`;
---

<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="light dark" />
    <meta name="theme-color" content="#ffffff" />

    <title>{fullTitle}</title>
    <meta name="title" content={fullTitle} />
    <meta name="description" content={description} />
    <meta name="author" content={siteConfig.author} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteConfig.url}/media/FRCCodeLab.png`} />
    <meta property="og:site_name" content="FRC Aides" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteConfig.url}/media/FRCCodeLab.png`} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
      integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA=="
      crossorigin="anonymous"
      referrerpolicy="no-referrer"
    />

    <link rel="icon" href={`${baseUrl}media/FRCCodeLabDark.svg`} type="image/svg+xml" />
    <link
      rel="icon"
      href={`${baseUrl}media/FRCCodeLabLight.svg`}
      type="image/svg+xml"
      media="(prefers-color-scheme: dark)"
    />
    <link rel="icon" href={`${baseUrl}media/FRCCodeLab.png`} type="image/png" sizes="any" />

    <script is:inline>
      (function () {
        var t = localStorage.getItem('frc-aides-theme');
        if (t === 'dark' || (!t && matchMedia('(prefers-color-scheme: dark)').matches))
          document.documentElement.setAttribute('data-theme', 'dark');
      })();
    </script>
  </head>
  <body>
    <div class="page">
      <Header currentPath={currentPath} />
      <main class="main">
        <div class="content">
          <div class="article-container">
            <article role="main" id="furo-main-content">
              <slot />
            </article>
          </div>
          <footer>
            <div class="bottom-of-page">
              <div class="left-details">
                <div class="copyright">Copyright © 2026 FRC Aides</div>
                <div class="copyright">
                  Tools from <a href={siteConfig.mantik} target="_blank" rel="noopener noreferrer">Mantik</a>
                </div>
              </div>
              <div class="right-details">
                <a href={siteConfig.github} target="_blank" rel="noopener noreferrer">GitHub</a>
              </div>
            </div>
          </footer>
        </div>
      </main>
    </div>
  </body>
</html>
